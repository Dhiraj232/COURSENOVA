# COURSENOVA — Unified Port 5000 Configuration (LOCAL ONLY)
# Copy this file to .env and fill in your secrets.

# ─── SERVER CONFIG ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# BASE_URL: Hardcoded for local port 5000
BASE_URL=https://coursenova.in

# FRONTEND_URL: Hardcoded for local port 5000 (Express Static Frontend)
FRONTEND_URL=https://coursenova.in
REACT_APP_API_URL=https://coursenova.in

# ─── DATABASE ────────────────────────────────────────────────────────────────
# Use your MongoDB Atlas connection string here
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/coursenova

# ─── AUTHENTICATION ──────────────────────────────────────────────────────────
# Get these from Google Cloud Console (https://console.cloud.google.com)
# Ensure authorized redirect URI is: https://coursenova.in/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT_SECRET: Any long random string for securing tokens
JWT_SECRET=Dhiraj@2026_secure_key_change_me!

# ─── PAYMENTS (Optional) ─────────────────────────────────────────────────────
CASHFREE_APP_ID=xxx
CASHFREE_SECRET_KEY=xxx
CASHFREE_ENV=TEST