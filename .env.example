# COURSENOVA — Unified Port 5000 Configuration (LOCAL ONLY)
# Copy this file to .env and fill in your secrets.

# ─── SERVER CONFIG ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# BASE_URL: Production environment
BASE_URL=https://www.coursenova.in

# FRONTEND_URL: Production frontend
FRONTEND_URL=https://www.coursenova.in
REACT_APP_API_URL=https://www.coursenova.in
GEMINI_API_KEY=AQ.Ab8RN6Jj-naRJ92YITjp_dO1n9yz977oaGr0Sqd6kLzwHi7EfQ

# ─── DATABASE ────────────────────────────────────────────────────────────────
# Use your MongoDB Atlas connection string here
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/coursenova

# ─── AUTHENTICATION ──────────────────────────────────────────────────────────
# Get these from Google Cloud Console (https://console.cloud.google.com)
# Ensure authorized redirect URI is: https://www.coursenova.in/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT_SECRET: Any long random string for securing tokens
JWT_SECRET=Dhiraj@2026_secure_key_change_me!

# ─── PAYMENTS (Razorpay) ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here



    